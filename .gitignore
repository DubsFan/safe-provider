# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# source images (large PNGs, converted to WebP in public/images/)
/images/

# source assets in public/images/ (keep only .webp and compressed .mp4 loops)
public/images/*.png
public/images/HERO.mp4
public/images/ASDFE.mp4
public/images/ASEHYDN.mp4
public/images/CLIPBOARD.mp4
public/images/FATHER AND DAUTHER.mp4
public/images/HANDOFF TWO BETTER.mp4
public/images/*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
